{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gurbani Captioning",
  "version": "0.2.1",
  "identifier": "dev.gurbani.captioning",
  "build": {
    "frontendDist": "../frontend-stub"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "binaries/gurbani-captioning"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      },
      "signingIdentity": "Developer ID Application: KARANBIR SINGH (KF66U685PK)",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}