  "lines": [
   {
    "index": 1,
    "text": "ਆਸਾ ਮਹਲਾ ੫ ॥",
    "transliteration": "aasaa mahalaa panjavaa ||"
   },
   {
    "index": 2,
    "text": "ਚਰਨ ਕਮਲ ਕੀ ਆਸ ਪਿਆਰੇ ॥",
    "transliteration": "charan kamal kee aas piaare ||"
   },
   {
    "index": 3,
    "text": "ਜਮਕੰਕਰ ਨਸਿ ਗਏ ਵਿਚਾਰੇ ॥੧॥",
    "transliteration": "jamaka(n)kar nas ge vichaare ||1||"
   },
   {
    "index": 4,
    "text": "ਤੂ ਚਿਤਿ ਆਵਹਿ ਤੇਰੀ ਮਇਆ ॥",
    "transliteration": "too chit aaveh teree miaa ||"
   },
   {
    "index": 5,
    "text": "ਸਿਮਰਤ ਨਾਮ ਸਗਲ ਰੋਗ ਖਇਆ ॥੧॥ ਰਹਾਉ ॥",
    "transliteration": "simarat naam sagal rog khiaa ||1|| rahaau ||"
   },
   {
    "index": 6,
    "text": "ਅਨਿਕ ਦੂਖ ਦੇਵਹਿ ਅਵਰਾ ਕਉ ॥",
    "transliteration": "anik dhookh dheveh avaraa kau ||"
   },
   {
    "index": 7,
    "text": "ਪਹੁਚਿ ਨ ਸਾਕਹਿ ਜਨ ਤੇਰੇ ਕਉ ॥੨॥",
    "transliteration": "pahuch na saakeh jan tere kau ||2||"
   },
   {
    "index": 8,
    "text": "ਦਰਸ ਤੇਰੇ ਕੀ ਪਿਆਸ ਮਨਿ ਲਾਗੀ ॥",
    "transliteration": "dharas tere kee piaas man laagee ||"
   },
   {
    "index": 9,
    "text": "ਸਹਜ ਅਨੰਦ ਬਸੈ ਬੈਰਾਗੀ ॥੩॥",
    "transliteration": "sahaj ana(n)dh basai bairaagee ||3||"
   },
   {
    "index": 10,
    "text": "ਨਾਨਕ ਕੀ ਅਰਦਾਸਿ ਸੁਣੀਜੈ ॥",
    "transliteration": "naanak kee aradhaas suneejai ||"
   },
   {
    "index": 11,
    "text": "ਕੇਵਲ ਨਾਮੁ ਰਿਦੇ ਮਹਿ ਦੀਜੈ ॥੪॥੨੬॥੭੭॥",
    "transliteration": "keval naam ridhe meh dheejai ||4||26||77||"
   }
  ],
  "confidence": 1.0
 },
