  "lines": [
    {
      "line_idx": 0,
      "text": "ਸਾਰਗ ਮਹਲਾ"
    },
    {
      "line_idx": 1,
      "text": "ਪੋਥੀ ਪਰਮੇਸਰ ਕਾ ਥਾਨੁ"
    },
    {
      "line_idx": 2,
      "text": "ਸਾਧਸੰਗਿ ਗਾਵਹਿ ਗੁਣ ਗੋਬਿੰਦ ਪੂਰਨ ਬ੍ਰਹਮ ਗਿਆਨੁ"
    },
    {
      "line_idx": 3,
      "text": "ਸਾਧਿਕ ਸਿਧ ਸਗਲ ਮੁਨਿ ਲੋਚਹਿ ਬਿਰਲੇ ਲਾਗੈ ਧਿਆਨੁ"
    },
    {
      "line_idx": 4,
      "text": "ਜਿਸਹਿ ਕ੍ਰਿਪਾਲੁ ਹੋਇ ਮੇਰਾ ਸੁਆਮੀ ਪੂਰਨ ਤਾ ਕੋ ਕਾਮੁ"
    },
    {
      "line_idx": 5,
      "text": "ਜਾ ਕੈ ਰਿਦੈ ਵਸੈ ਭੈ ਭੰਜਨੁ ਤਿਸੁ ਜਾਨੈ ਸਗਲ ਜਹਾਨੁ"
    },
    {
      "line_idx": 6,
      "text": "ਖਿਨੁ ਪਲੁ ਬਿਸਰੁ ਨਹੀ ਮੇਰੇ ਕਰਤੇ ਇਹੁ ਨਾਨਕੁ ਮਾਂਗੈ ਦਾਨੁ"
    }
  ],
